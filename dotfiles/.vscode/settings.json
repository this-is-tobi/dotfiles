{
  // visuals
  "telemetry.telemetryLevel": "off",
  "window.autoDetectColorScheme": true,
  "workbench.preferredLightColorTheme": "GitHub Light Default",
  "workbench.preferredDarkColorTheme": "GitHub Dark Default",
  "workbench.colorTheme": "GitHub Dark Default",
  "workbench.fontAliasing": "antialiased",
  "workbench.iconTheme": "material-icon-theme",
  "workbench.editor.showTabs": "multiple",
  "terminal.integrated.fontFamily": "Hack Nerd Font Mono",
  "editor.fontFamily": "Input Mono, Fira Code, monospace",
  "editor.fontLigatures": "'ss01', 'ss02', 'ss03', 'ss06', 'zero'",
  "editor.cursorBlinking": "phase",
  "editor.suggestSelection": "first",
  "editor.wordWrap": "on",
  "editor.bracketPairColorization.enabled": true,
  "editor.tabSize": 2,
  "editor.minimap.enabled": false,
  "search.exclude": {
    "**/.git": true,
    "**/.nuxt": true,
    "**/.pnpm": true,
    "**/.vscode": true,
    "**/.yarn": true,
    "**/dist/**": true,
    "**/logs": true,
    "**/node_modules": true,
    "**/out/**": true,
    "**/package-lock.json": true,
    "**/bun.lock": true,
    "**/bun.lockb": true,
    "**/pnpm-lock.yaml": true,
    "**/yarn.lock": true
  },
  "diffEditor.ignoreTrimWhitespace": false,
  // general
  "editor.unicodeHighlight.invisibleCharacters": false,
  "security.workspace.trust.untrustedFiles": "open",
  "workbench.startupEditor": "none",
  // git
  "git.autofetch": true,
  "git.untrackedChanges": "separate",
  "git.addAICoAuthor": "off",
  // github
  "githubPullRequests.pullBranch": "never",
  // eslint
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit",
    "source.organizeImports": "never"
  },
  "eslint.format.enable": true,
  "eslint.quiet": true,
  "eslint.validate": [
    "javascript",
    "typescript",
    "javascriptreact",
    "typescriptreact",
    "vue",
    "html",
    "markdown",
    "json",
    "jsonc",
    "json5"
  ],
  // stylelint
  "css.validate": false,
  "less.validate": true,
  "scss.validate": true,
  "files.associations": {
    "*.css": "postcss",
    "*.hcl": "terraform"
  },
  // languages
  "[typescript]": {
    "editor.defaultFormatter": "dbaeumer.vscode-eslint"
  },
  "js/ts.preferences.quoteStyle": "single",
  "js/ts.preferences.importModuleSpecifierEnding": "auto",
  "js/ts.preferences.preferTypeOnlyAutoImports": true,
  "js/ts.suggest.jsdoc.enabled": true,
  "js/ts.suggest.jsdoc.generateReturns": true,
  "js/ts.inlayHints.parameterNames.enabled": "literals",
  "js/ts.inlayHints.parameterTypes.enabled": false,
  "js/ts.inlayHints.variableTypes.enabled": false,
  "js/ts.inlayHints.functionLikeReturnTypes.enabled": true,
  "js/ts.inlayHints.enumMemberValues.enabled": true,
  "[javascript]": {
    "editor.defaultFormatter": "dbaeumer.vscode-eslint"
  },
  "[html]": {
    "editor.defaultFormatter": "dbaeumer.vscode-eslint"
  },
  "[markdown]": {
    "editor.quickSuggestions": {
      "other": true,
      "comments": true,
      "strings": true
    },
    "editor.formatOnSave": true,
    "editor.formatOnPaste": true,
    "editor.defaultFormatter": "yzhang.markdown-all-in-one"
  },
  "[terraform]": {
    "editor.defaultFormatter": "hashicorp.terraform",
    "editor.formatOnSave": true
  },
  // yaml — disable validation globally, re-enable only for plain yaml files
  // (prevents Red Hat YAML extension from validating Helm templates)
  "yaml.validate": false,
  "yaml.schemas": {
    "https://json.schemastore.org/chart.json": "**/helm/Chart.yaml"
  },
  "redhat.telemetry.enabled": false,
  "[yaml]": {
    "editor.defaultFormatter": "redhat.vscode-yaml"
  },
  "[helm-template]": {
    "editor.formatOnSave": false
  },
  "go.toolsManagement.autoUpdate": true,
  // conventional commits
  "conventionalCommits.showNewVersionNotes": false,
  // kubernetes
  "vs-kubernetes": {
    "vs-kubernetes.crd-code-completion": "enabled"
  },
  "vscode-kubernetes.log-viewer.follow": true,
  "vscode-kubernetes.log-viewer.timestamp": false,
  "vscode-kubernetes.log-viewer.since": -1,
  "vscode-kubernetes.log-viewer.tail": -1,
  "vscode-kubernetes.log-viewer.destination": "Webview",
  "vscode-kubernetes.log-viewer.wrap": true,
  // markdown preview
  "markdown-preview-enhanced.previewTheme": "github-dark.css",
  "markdown-preview-enhanced.codeBlockTheme": "github-dark.css",
  // extensions
  "database-client.autoSync": true,
  // copilot
  "github.copilot.chat.agent.autoFix": true,
  "github.copilot.chat.reviewAgent.enabled": true,
  "github.copilot.chat.languageContext.fix.typescript.enabled": true,
  "github.copilot.chat.languageContext.inline.typescript.enabled": true,
  "github.copilot.chat.languageContext.typescript.enabled": true,
  "github.copilot.editor.enableCodeActions": false,
  "github.copilot.nextEditSuggestions.enabled": true,
  "github.copilot.enable": {
    "*": true,
    "markdown": true,
    "plaintext": false,
    "scminput": false
  },
  // instructions — ~/.copilot/instructions/ loaded in every repo
  "chat.instructionsFilesLocations": {
    ".github/instructions": true,
    "~/.copilot/instructions": true
  },
  "chat.includeApplyingInstructions": true,
  "chat.useAgentsMdFile": true,
  "chat.useClaudeMdFile": true,
  // per-feature instructions: commit, PR, review
  // note: ~ expansion requires VS Code to support it; use full path if not working
  "github.copilot.chat.commitMessageGeneration.instructions": [
    { "file": "~/.copilot/instructions/commit-message.instructions.md" }
  ],
  "github.copilot.chat.pullRequestDescriptionGeneration.instructions": [
    { "file": "~/.copilot/instructions/pull-request.instructions.md" }
  ],
  "github.copilot.chat.reviewSelection.instructions": [
    { "file": "~/.copilot/instructions/code-review.instructions.md" }
  ],
  // skills — personal ~/.copilot/skills/ and ~/.claude/skills/ enabled by default
  "chat.useAgentSkills": true,
  "chat.agentSkillsLocations": {
    ".github/skills": true,
    ".claude/skills": true,
    "~/.copilot/skills": true,
    "~/.claude/skills": true
  },
  "chat.useHooks": true,
  "chat.hookFilesLocations": {
    "~/.copilot/hooks": true
  },
  // agents
  "chat.agentFilesLocations": {
    ".github/agents": true,
    "~/.copilot/agents": true
  },
  "github.copilot.chat.tools.memory.enabled": true,
  "github.copilot.chat.backgroundAgent.enabled": true,
  "chat.agent.maxRequests": 100,
  "chat.tools.edits.autoApprove": {
    "**/*": true,
    "**/.vscode/*.json": false,
    "**/.git/**": false,
    "**/{package.json,package-lock.json,server.xml,build.rs,web.config,.gitattributes,.env}": false,
    "**/.env*": false,
    "**/*.{csproj,fsproj,vbproj}": false
  },
  "chat.tools.terminal.autoApprove": {
    // ── filesystem / info ─────────────────────────────────────────────────
    "cd": true,
    "echo": true,
    "ls": true,
    "pwd": true,
    "cat": true,
    "head": true,
    "tail": true,
    "findstr": true,
    "wc": true,
    "tr": true,
    "cut": true,
    "cmp": true,
    "diff": true,
    "which": true,
    "type": true,
    "basename": true,
    "dirname": true,
    "realpath": true,
    "readlink": true,
    "stat": true,
    "file": true,
    "du": true,
    "df": true,
    "lsof": true,
    "uname": true,
    "hostname": true,
    "whoami": true,
    "id": true,
    "uptime": true,
    "sleep": true,
    // ── text processing ───────────────────────────────────────────────────
    "awk": true,
    "sed": true,
    "/^sed\\b.*-i\\b/": false,            // block in-place edits
    "jq": true,
    "yq": true,
    "column": true,
    "/^column\\b.*-c\\s+[0-9]{4,}/": false,
    // ── search / find ─────────────────────────────────────────────────────
    "find": true,
    "/^find\\b.*-(delete|exec|execdir|fprint|fprintf|fls|ok|okdir)\\b/": false,
    "grep": true,
    "/^grep\\b.*-(f|P)\\b/": false,
    "sort": true,
    "/^sort\\b.*-(o|S)\\b/": false,
    "tree": true,
    "/^tree\\b.*-o\\b/": false,
    // ── date / time ───────────────────────────────────────────────────────
    "date": true,
    "/^date\\b.*(-s|--set)\\b/": false,
    "timeout": true,
    // ── network read-only ─────────────────────────────────────────────────
    "ping": true,
    "dig": true,
    "nslookup": true,
    "host": true,
    "netstat": true,
    "ss": true,
    // ── git (read-only) ───────────────────────────────────────────────────
    "git status": true,
    "git log": true,
    "git show": true,
    "git diff": true,
    // ── kubernetes: read-only auto-approved, mutations require confirmation
    "kubectl": true,
    "/^kubectl\\b.*(delete|apply|patch|\\bexec\\b|port-forward|\\brun\\b|scale|rollout\\s+restart|create|edit|replace|drain|taint|cordon|uncordon|label|annotate|set\\s+image)/": false,
    // ── helm: query/template auto-approved, cluster mutations require confirmation
    "helm": true,
    "/^helm\\b.*(install|upgrade|uninstall|delete|rollback)/": false,
    // ── docker: inspection auto-approved, run/exec/push/destructive require confirmation
    "docker": true,
    "/^docker\\b.*(\\brun\\b|\\bexec\\b|\\brm\\b|\\brmi\\b|prune|\\bpush\\b|\\bsave\\b|login|logout|swarm|secret|\\bnetwork\\s+(create|rm|remove)\\b|\\bvolume\\s+(create|rm|remove)\\b)/": false,
    // ── js / ts runtimes ─────────────────────────────────────────────────
    "bun": true,
    "bunx": true,
    "pnpm": true,
    // ── go ───────────────────────────────────────────────────────────────
    "go": true,
    "/^go\\b.*(install|get)\\b/": false,  // block fetching/installing packages
    // ── PowerShell read-only ─────────────────────────────────────────────
    "Get-ChildItem": true,
    "Get-Content": true,
    "Get-Date": true,
    "Get-Random": true,
    "Get-Location": true,
    "Write-Host": true,
    "Write-Output": true,
    "Split-Path": true,
    "Join-Path": true,
    "Start-Sleep": true,
    "Where-Object": true,
    "/^Select-[a-z0-9]/i": true,
    "/^Measure-[a-z0-9]/i": true,
    "/^Compare-[a-z0-9]/i": true,
    "/^Format-[a-z0-9]/i": true,
    "/^Sort-[a-z0-9]/i": true,
    // ── shell injection guards ────────────────────────────────────────────
    "/\\(.+\\)/": { "approve": false, "matchCommandLine": true },
    "/\\{.+\\}/": { "approve": false, "matchCommandLine": true },
    "/`.+`/": { "approve": false, "matchCommandLine": true },
    // ── always blocked: destructive / remote access / privilege ───────────
    "rm": false,
    "del": false,
    "dd": false,
    "erase": false,
    "kill": false,
    "ps": false,
    "top": false,
    // remote access — never auto-approve
    "ssh": false,
    "scp": false,
    "sftp": false,
    "rsync": false,
    "nc": false,
    "ncat": false,
    "netcat": false,
    "socat": false,
    "mosh": false,
    // network write
    "curl": false,
    "wget": false,
    // privilege / ownership changes
    "chmod": false,
    "chown": false,
    "sudo": false,
    "su": false,
    // code execution / injection
    "eval": false,
    "xargs": false,
    // PowerShell destructive
    "Remove-Item": false,
    "ri": false,
    "rd": false,
    "rmdir": false,
    "Stop-Process": false,
    "spps": false,
    "taskkill": false,
    "taskkill.exe": false,
    "Invoke-RestMethod": false,
    "Invoke-WebRequest": false,
    "irm": false,
    "iwr": false,
    "Set-ItemProperty": false,
    "sp": false,
    "Set-Acl": false,
    "Invoke-Expression": false,
    "iex": false,
  },
  "chat.tools.global.autoApprove": false,
  "chat.mcp.autostart": "newAndOutdated",
  "chat.mcp.gallery.enabled": true,
  "chat.mcp.serverSampling": {},
  "chat.tools.urls.autoApprove": {
    "https://code.visualstudio.com": true,
    "https://github.com/microsoft/vscode/wiki/*": true,
    "https://artifacthub.io": true,
  },
}
